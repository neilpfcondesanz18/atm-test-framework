root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.java]
indent_size = 4
max_line_length = 120

[*.{yml,yaml}]
indent_size = 2

[*.xml]
indent_size = 2

[*.properties]
indent_size = 4

[*.{feature,md}]
indent_size = 2
trim_trailing_whitespace = false
