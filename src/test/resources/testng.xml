<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="ATM Banking Test Suite" parallel="methods" thread-count="4" verbose="1">

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <test name="API Tests - Accounts">
        <classes>
            <class name="com.atm.runners.ApiTestRunner"/>
        </classes>
    </test>

    <test name="All Tests">
        <classes>
            <class name="com.atm.runners.TestRunner"/>
        </classes>
    </test>

</suite>
